# Copy this to .env and fill in your values
# Never commit .env to git

# Server
PORT=8080
ENV=development   # development | production

# Database — get this from Railway after you create a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/simtrader?sslmode=require

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex

# Token expiry
JWT_ACCESS_EXPIRY=15m     # Access tokens expire fast — short window if stolen
JWT_REFRESH_EXPIRY=7d     # Refresh tokens last a week

# Email — for sending invite + password reset emails (use Resend.com free tier)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL — for CORS and email links
FRONTEND_URL=http://localhost:5173
