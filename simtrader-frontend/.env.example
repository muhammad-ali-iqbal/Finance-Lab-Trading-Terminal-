# Copy to .env.local for development
# Vite only exposes variables prefixed with VITE_

# Development: proxy in vite.config.ts handles /api → localhost:8080
# so you can leave this blank locally.
VITE_API_URL=

# WebSocket URL — in development points to Go backend
# In production: wss://your-railway-app.railway.app
VITE_WS_URL=ws://localhost:8080
